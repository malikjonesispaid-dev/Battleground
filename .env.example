# Copy this file to .env and fill in what you have.
# The app runs with zero config in DRY_RUN mode (nothing is actually posted).

DATABASE_URL="file:./dev.db"

# Optional. Without this, content generation falls back to a deterministic
# template generator so the app still works end to end with no API key.
ANTHROPIC_API_KEY=

# When true (default), the publisher logs what it *would* post instead of
# calling real platform APIs. Set to "false" only once you've filled in real
# credentials on each Page and understand what you're authorizing.
DRY_RUN=true

# Required only if DRY_RUN=false and you have Instagram/Facebook Pages
# connected via the Meta Graph API.
META_GRAPH_API_VERSION=v21.0

# Required only if DRY_RUN=false and you have a YouTube page. See README for
# the OAuth setup — a static API key is not sufficient for uploads.
YOUTUBE_API_KEY=
