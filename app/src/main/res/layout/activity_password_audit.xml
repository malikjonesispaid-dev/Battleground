<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/accent"
        app:tabSelectedTextColor="@color/accent"
        app:tabTextColor="@color/white">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_hash_cracker" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_login_bruteforce" />
    </com.google.android.material.tabs.TabLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Hash cracker panel -->
            <LinearLayout
                android:id="@+id/hashPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <EditText
                    android:id="@+id/hashInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_hash"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <Spinner
                    android:id="@+id/algoSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/pickWordlistButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/hint_wordlist_path" />

                <CheckBox
                    android:id="@+id/hashAuthCheckbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/authorization_prompt"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/crackButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:enabled="false"
                    android:text="@string/action_crack" />

                <TextView
                    android:id="@+id/hashResultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Login brute force panel -->
            <LinearLayout
                android:id="@+id/bruteforcePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/loginUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_login_url"
                    android:inputType="textUri"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <EditText
                    android:id="@+id/usernameFieldInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/hint_username_field"
                    android:text="username"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <EditText
                    android:id="@+id/usernameValueInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/hint_username_value"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <EditText
                    android:id="@+id/passwordFieldInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/hint_password_field"
                    android:text="password"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <EditText
                    android:id="@+id/failureMarkerInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/hint_failure_marker"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <EditText
                    android:id="@+id/delayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/hint_delay_ms"
                    android:inputType="number"
                    android:text="1000"
                    android:textColor="@color/white"
                    android:textColorHint="#888888" />

                <CheckBox
                    android:id="@+id/bruteAuthCheckbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/authorization_prompt"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/bruteforceButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:enabled="false"
                    android:text="@string/action_start_bruteforce" />

                <TextView
                    android:id="@+id/bruteResultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/white" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
